# File: .env.example

# Run-time settings

# override the default 'config.yaml'
FINANCE_CONFIG=config.yaml

# settings for TimescaleDB
TIMESCALEDB_HOST=localhost
TIMESCALEDB_PORT=5432
TIMESCALEDB_SSL_MODE=verify_ca
TIMESCALEDB_USER=testuser
TIMESCALEDB_PASSWORD=my_secret_password
TIMESCALEDB_SSL_ROOT_CERT=/opt/certs/ca-all.crt

# SSL modes
#  - disable: no encryption.
#  - allow: prefer SSL, but silently fall back to unencrypted.
#  - require: encrypts the connection but does not validate the certificate
#  - verify-ca: encrypts and verifies the certificate is certified by a valid CA
#  - verify-full: like verify-ca but then also verifies the host name
#
# Only the last two are suitable for production.

FRED_API_KEY=MyFredApiKey
# Can also use other API keys if needed.
# format: PROVIDER_API_KEY=keyvalue, with PROVIDER the capitalized name of the section in config.ini
# Supported providers: yahoo, ecb, fred
