# File: tests/test_fetch_json.py

import pytest
import requests

from finance.fetch.yahoo import YahooProvider


def test_fetch_json_success(monkeypatch):
    provider = YahooProvider()

    class FakeResponse:
        status_code = 200

        def raise_for_status(self):
            pass

        def json(self):
            return {"ok": True}

    monkeypatch.setattr("requests.get", lambda url, timeout: FakeResponse())

    assert provider._fetch_json("http://example.com") == {"ok": True}


def test_fetch_json_non_200(monkeypatch):
    provider = YahooProvider()

    class FakeResponse:
        def raise_for_status(self):
            raise requests.exceptions.HTTPError("boom")

    monkeypatch.setattr("requests.get", lambda url, timeout: FakeResponse())

    with pytest.raises(requests.exceptions.HTTPError):
        provider._fetch_json("http://example.com")


def test_fetch_json_json_decode_error(monkeypatch):
    provider = YahooProvider()

    class FakeResponse:
        status_code = 200

        def raise_for_status(self):
            pass

        def json(self):
            raise ValueError("invalid JSON")

    monkeypatch.setattr("requests.get", lambda url, timeout: FakeResponse())

    with pytest.raises(ValueError):
        provider._fetch_json("http://example.com")


def test_fetch_json_network_error(monkeypatch):
    provider = YahooProvider()

    def fake_get(url, timeout):
        raise requests.exceptions.ConnectionError("no network")

    monkeypatch.setattr("requests.get", fake_get)

    with pytest.raises(requests.exceptions.ConnectionError):
        provider._fetch_json("http://example.com")
